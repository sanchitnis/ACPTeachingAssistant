{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "REVA: Get Help",
      "type": "shell",
      "command": "python",
      "args": ["scripts/help.py", "${file}"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "REVA: Grade My Code",
      "type": "shell",
      "command": "python",
      "args": ["scripts/grade.py", "${file}"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "REVA: Next Exercise",
      "type": "shell",
      "command": "python",
      "args": ["scripts/next.py", "${input:studentId}"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "REVA: Register Student",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/init_student.py",
        "${input:studentId}",
        "${input:studentName}",
        "${input:studentSection}",
        "${input:studentGrade}"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "studentId",
      "description": "Your REVA student ID (e.g. raj22cs045)",
      "type": "promptString"
    },
    {
      "id": "studentName",
      "description": "Your full name (e.g. Raj Kumar)",
      "type": "promptString"
    },
    {
      "id": "studentSection",
      "description": "Your section (e.g. BTech-CS-2B)",
      "type": "promptString"
    },
    {
      "id": "studentGrade",
      "description": "Your 1st sem C Programming grade (O/A+/A/B+/B/C+/C/F)",
      "type": "promptString"
    }
  ]
}
